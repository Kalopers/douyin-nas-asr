# =========================
# App configuration
# =========================
APP_HOST=0.0.0.0
APP_PORT=17650
WORKER_POLL_INTERVAL_SECONDS=2.0
WORKER_CONCURRENCY=1
DY_API_KEY=change_me_to_your_secure_key
API_KEY_HEADER_NAME=X-API-KEY

# =========================
# NAS paths (inside container)
# =========================
NAS_JSON_DIR=/app/data/json
NAS_VIDEO_DIR=/app/data/videos
NAS_IMAGE_DIR=/app/data/images

# =========================
# Database
# =========================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=myuser
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_DB=app_data

# =========================
# ASR / SenseVoice / faster-whisper
# =========================
ASR_BACKEND=sensevoice
ASR_MODEL=iic/SenseVoiceSmall
ASR_MAX_CONCURRENCY=1
FASTER_WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=4

# =========================
# Douyin / third-party API
# =========================
DY_TIKHUB_AUTH_KEY=your_tikhub_key_here
